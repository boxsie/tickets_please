{{define "_nav.tmpl"}}<header class="topbar">
  <a class="brand" href="/">tickets_please</a>
  {{if .CurrentSlug}}
  <form class="search topbar-search" method="get" action="/p/{{.CurrentSlug}}/search" role="search">
    <span class="search-icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.34-4.34m0 0A7.5 7.5 0 1 0 6.06 6.06a7.5 7.5 0 0 0 10.6 10.6Z" />
      </svg>
    </span>
    <input type="search" name="q" placeholder="Search this project…" aria-label="Search project" autocomplete="off" spellcheck="false">
  </form>
  {{end}}
  <a class="topbar-link" href="/settings">Settings</a>
  {{if .Chrome.AgentLabel}}<span class="agent" title="Web UI session — visible in the audit trail">{{.Chrome.AgentLabel}}</span>{{end}}
</header>
{{end}}
