{{define "main"}}
{{- $f := .Body -}}
{{- $p := $f.Project -}}
{{- $s := $f.Status -}}
<section class="form-page">
  <header class="page-header">
    <h1>{{$p.Name}} · settings</h1>
    <p class="subtitle">
      Slug <code>{{$p.Slug}}</code> is immutable.
      Edit the long-form summary on the <a href="/p/{{$p.Slug}}/summary">Summary page</a>.
    </p>
  </header>

  <section class="card" aria-label="Embedding status">
    <h2>Embedding status</h2>
    {{if $s.SidecarPresent}}
      <p>
        Embedded with <code>{{$s.SidecarProvider}}/{{$s.SidecarModel}}</code>
        (<code>{{$s.SidecarDim}}d</code>).
        {{if or (ne $s.SidecarProvider $s.ExpectedProvider) (ne $s.SidecarModel $s.ExpectedModel)}}
          Project record asks for <code>{{$s.ExpectedProvider}}/{{$s.ExpectedModel}}</code> —
          re-embed to bring sidecars in line.
        {{end}}
      </p>
    {{else}}
      <p class="hint">No sidecars yet. Either this project was just created or a re-embed is in flight.</p>
    {{end}}
    <form method="post" action="/p/{{$p.Slug}}/reembed"
          hx-confirm="This will rebuild all embeddings for this project.">
      <input type="hidden" name="_csrf" value="{{.Chrome.CSRF}}">
      <button type="submit" class="btn">Re-embed project</button>
    </form>
  </section>

  {{if $f.FormError}}<div class="form-error" role="alert"><strong>Error:</strong> {{$f.FormError}}</div>{{end}}
  <form method="post" action="/p/{{$p.Slug}}/settings" class="stack">
    <label for="name">Name</label>
    <input type="text" id="name" name="name" required value="{{$f.Submitted.Name}}">

    <label for="description">Description</label>
    <input type="text" id="description" name="description" value="{{$f.Submitted.Description}}">

    <label for="embed_provider">Embed provider</label>
    <select id="embed_provider" name="embed_provider">
      <option value="ollama"{{if eq $f.Submitted.EmbedProvider "ollama"}} selected{{end}}>ollama</option>
      <option value="openai"{{if eq $f.Submitted.EmbedProvider "openai"}} selected{{end}}>openai</option>
    </select>

    <label for="embed_model">Embed model <span class="muted">(provider-specific identifier)</span></label>
    <input type="text" id="embed_model" name="embed_model" value="{{$f.Submitted.EmbedModel}}"
           placeholder="e.g. nomic-embed-text or text-embedding-3-small">

    <input type="hidden" name="_csrf" value="{{.Chrome.CSRF}}">
    <div class="form-actions">
      <button type="submit">Save settings</button>
      <a class="btn-link" href="/p/{{$p.Slug}}">Cancel</a>
    </div>
    <p class="hint">Changing the provider or model triggers a full re-embed automatically.</p>
  </form>
</section>
{{end}}
