{{define "main"}}
{{- $b := .Body -}}
{{- $p := $b.Project -}}
<section class="search-page">
  <header class="page-header">
    <h1>Search {{$p.Name}}</h1>
    <p class="subtitle">
      <code>{{$p.Slug}}</code>
      <span class="breadcrumb-sep"></span>
      Vector search inside this project's tickets, comments, and learnings.
    </p>
  </header>

  <form method="get" action="/p/{{$p.Slug}}/search" class="search-form">
    <input type="search" name="q" autofocus placeholder="What are we looking for?"
           value="{{$b.Query}}"
           hx-get="/p/{{$p.Slug}}/search"
           hx-trigger="keyup changed delay:300ms, search"
           hx-include="[name='kind'],[name='limit']"
           hx-target="#results"
           hx-swap="innerHTML"
           hx-sync="this:replace">
    <input type="hidden" name="kind" value="{{$b.Kind}}">
    <input type="hidden" name="limit" value="{{$b.Limit}}">

    <nav class="search-tabs" aria-label="Search kind">
      {{range $k := list "learnings" "tickets" "comments"}}
      <a class="search-tab{{if eq $k $b.Kind}} active{{end}}"
         href="/p/{{$p.Slug}}/search?q={{$b.Query}}&kind={{$k}}">{{$k}}</a>
      {{end}}
    </nav>
  </form>

  <div id="results" class="search-results">
    {{template "project_search_results.tmpl" $b}}
  </div>
</section>
{{end}}
