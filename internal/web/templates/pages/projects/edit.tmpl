{{define "main"}}
{{- $f := .Body -}}
{{- $p := $f.Project -}}
<section class="form-page">
  <header class="page-header">
    <h1>Edit {{$p.Name}}</h1>
    <p class="subtitle">
      Slug <code>{{$p.Slug}}</code> is immutable.
      Edit summary on the <a href="/p/{{$p.Slug}}/summary">Summary page</a>.
    </p>
  </header>
  {{if $f.FormError}}<div class="form-error" role="alert"><strong>Error:</strong> {{$f.FormError}}</div>{{end}}
  <form method="post" action="/p/{{$p.Slug}}" class="stack">
    <label for="name">Name</label>
    <input type="text" id="name" name="name" required value="{{$f.Submitted.Name}}">

    <label for="description">Description</label>
    <input type="text" id="description" name="description" value="{{$f.Submitted.Description}}">

    <input type="hidden" name="_csrf" value="{{.Chrome.CSRF}}">
    <div class="form-actions">
      <button type="submit">Save</button>
      <a class="btn-link" href="/p/{{$p.Slug}}">Cancel</a>
    </div>
  </form>
</section>
{{end}}
