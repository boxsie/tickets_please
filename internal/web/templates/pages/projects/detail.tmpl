{{define "main"}}
{{- $p := .Body.Project -}}
{{- $phaseCount := .Body.PhaseCount -}}
<section class="project-detail">
  <header class="page-header">
    <h1>{{$p.Name}}</h1>
    <p class="subtitle">
      <code>{{$p.Slug}}</code>
      {{if $p.Description}}<span class="breadcrumb-sep"></span>{{$p.Description}}{{end}}
    </p>
    <div class="page-actions">
      <a class="btn btn-primary" href="/p/{{$p.Slug}}/board">Open board</a>
      <a class="btn" href="/p/{{$p.Slug}}/edit">Edit</a>
      <a class="btn" href="/p/{{$p.Slug}}/summary">Summary</a>
    </div>
  </header>

  <nav class="tabs" aria-label="Project sections">
    <a class="tab" href="/p/{{$p.Slug}}/board">Board</a>
    <a class="tab" href="/p/{{$p.Slug}}/phases">Phases ({{$phaseCount}})</a>
    <a class="tab" href="/p/{{$p.Slug}}/waves">Waves</a>
    <a class="tab" href="/p/{{$p.Slug}}/summary">Summary</a>
  </nav>

  <section class="card">
    <h2>Summary</h2>
    {{if $p.Summary}}
    <div class="markdown">{{markdown $p.Summary}}</div>
    <p style="margin-top: 1rem;"><a href="/p/{{$p.Slug}}/summary">Open the full summary editor →</a></p>
    {{else}}
    <p class="hint">No summary set. <a href="/p/{{$p.Slug}}/summary?edit=1">Add one →</a></p>
    {{end}}
  </section>

  {{if .Body.Phases}}
  <section class="card">
    <h2>Phases</h2>
    <ul class="bare-list">
      {{range .Body.Phases}}
      <li><a href="/p/{{$p.Slug}}/phases/{{.Slug}}">{{.Name}}</a> <span class="muted">— {{.ActiveTicketCount}} active / {{.TicketCount}} total</span></li>
      {{end}}
    </ul>
  </section>
  {{end}}

  <details class="danger-zone">
    <summary>Delete project</summary>
    <p class="hint">
      Removes <code>{{$p.Slug}}</code> and all its phases, tickets, comments,
      and embeddings. Refuses if any ticket is still active (not <code>done</code>).
      Cannot be undone — the on-disk data is gone.
    </p>
    <form method="post" action="/p/{{$p.Slug}}/delete" onsubmit="return confirm('Delete project {{$p.Slug}} and ALL its phases/tickets/comments? This cannot be undone.');">
      <input type="hidden" name="_csrf" value="{{.Chrome.CSRF}}">
      <input type="hidden" name="confirm" value="yes">
      <button type="submit" class="btn btn-danger">Delete this project</button>
    </form>
  </details>
</section>
{{end}}
