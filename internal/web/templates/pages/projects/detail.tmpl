{{define "main"}}
{{- $b := .Body -}}
{{- $p := $b.Project -}}
{{- $m := $b.Metrics -}}
<section class="project-detail dashboard">
  <header class="page-header">
    <h1>{{$p.Name}}</h1>
    <p class="subtitle">
      <code>{{$p.Slug}}</code>
      {{if $p.Description}}<span class="breadcrumb-sep"></span>{{$p.Description}}{{end}}
    </p>
    <div class="page-actions">
      <a class="btn btn-primary" href="/p/{{$p.Slug}}/board">Open board</a>
      <a class="btn" href="/p/{{$p.Slug}}/tickets/new">New ticket</a>
      <a class="btn" href="/p/{{$p.Slug}}/edit">Edit</a>
      <a class="btn" href="/p/{{$p.Slug}}/summary">Summary</a>
    </div>
  </header>

  <section class="metric-grid" aria-label="Headline metrics">
    <div class="metric-card">
      <div class="metric-label">Total</div>
      <div class="metric-value">{{$m.Total}}</div>
      <div class="metric-hint">tickets in this project</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Active</div>
      <div class="metric-value">{{$m.Active}}</div>
      <div class="metric-hint">not yet done</div>
    </div>
    <div class="metric-card metric-card-accent">
      <div class="metric-label">In progress</div>
      <div class="metric-value">{{$m.InProgress}}</div>
      <div class="metric-hint">currently being worked</div>
    </div>
    <div class="metric-card metric-card-success">
      <div class="metric-label">Done</div>
      <div class="metric-value">{{$m.Done}}</div>
      <div class="metric-hint">completed</div>
    </div>
  </section>

  {{if $m.Total}}
  <section class="card">
    <h2>Status distribution</h2>
    <div class="status-bar">
      {{range $b.StatusSegments}}
      {{if .Count}}<div class="status-bar-segment status-bar-{{.Column}}" style="width: {{.Percent}}%" title="{{.Label}}: {{.Count}} ({{.Percent}}%)"></div>{{end}}
      {{end}}
    </div>
    <ul class="status-bar-legend">
      {{range $b.StatusSegments}}
      <li><span class="dot dot-{{.Column}}"></span>{{.Label}} <strong>{{.Count}}</strong> <span class="muted">({{.Percent}}%)</span></li>
      {{end}}
    </ul>
  </section>
  {{end}}

  <div class="dashboard-grid">
    <section class="card">
      <h2>Ready to pick up</h2>
      {{if $b.ReadyTickets}}
      <ul class="ticket-list">
        {{range $b.ReadyTickets}}
        <li>
          <a class="ticket-list-title" href="/tickets/{{.ID}}?slug={{$p.Slug}}">{{.Title}}</a>
          <div class="ticket-list-meta">
            <span class="badge badge-{{.Column}}">{{.Column}}</span>
            {{if ne .Wave 0}}<span class="muted">w{{.Wave}}</span>{{end}}
          </div>
        </li>
        {{end}}
      </ul>
      {{else}}
      <p class="hint">All ready work is claimed. Nice.</p>
      {{end}}
    </section>

    <section class="card">
      <h2>Recent activity</h2>
      {{if $b.RecentActivity}}
      <ul class="ticket-list">
        {{range $b.RecentActivity}}
        <li>
          <a class="ticket-list-title" href="/tickets/{{.Ticket.ID}}?slug={{$p.Slug}}">{{.Ticket.Title}}</a>
          <div class="ticket-list-meta">
            <span class="badge badge-{{.Ticket.Column}}">{{.Ticket.Column}}</span>
            <span class="muted">updated {{.Ago}}</span>
          </div>
        </li>
        {{end}}
      </ul>
      {{else}}
      <p class="hint">No tickets yet.</p>
      {{end}}
    </section>
  </div>

  {{if $b.RecentLearnings}}
  <section class="card">
    <h2>Recent learnings</h2>
    <ul class="learning-list">
      {{range $b.RecentLearnings}}
      <li>
        <div class="learning-meta">
          <a class="learning-title" href="/tickets/{{.Ticket.ID}}?slug={{$p.Slug}}">{{.Ticket.Title}}</a>
          <span class="muted">completed {{.Ago}}</span>
        </div>
        <p class="learning-excerpt">{{.Excerpt}}</p>
      </li>
      {{end}}
    </ul>
    <p class="hint" style="margin-top: 0.75rem;"><a href="/search?q=&kind=learnings&slug={{$p.Slug}}">Search all learnings →</a></p>
  </section>
  {{end}}

  {{if $b.Phases}}
  <section class="card">
    <h2>Phases</h2>
    <table class="data-table">
      <thead>
        <tr><th>Name</th><th>Slug</th><th>Active / Total</th></tr>
      </thead>
      <tbody>
        {{range $b.Phases}}
        <tr>
          <td><a href="/p/{{$p.Slug}}/phases/{{.Slug}}">{{.Name}}</a></td>
          <td><code>{{.Slug}}</code></td>
          <td>{{.ActiveTicketCount}} / {{.TicketCount}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </section>
  {{end}}

  <details class="danger-zone">
    <summary>Delete project</summary>
    <p class="hint">
      Removes <code>{{$p.Slug}}</code> and all its phases, tickets, comments,
      and embeddings. Refuses if any ticket is still active (not <code>done</code>).
      Cannot be undone — the on-disk data is gone.
    </p>
    <form method="post" action="/p/{{$p.Slug}}/delete" onsubmit="return confirm('Delete project {{$p.Slug}} and ALL its phases/tickets/comments? This cannot be undone.');">
      <input type="hidden" name="_csrf" value="{{.Chrome.CSRF}}">
      <input type="hidden" name="confirm" value="yes">
      <button type="submit" class="btn btn-danger">Delete this project</button>
    </form>
  </details>
</section>
{{end}}
