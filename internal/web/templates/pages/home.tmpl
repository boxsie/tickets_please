{{define "main"}}
<section class="empty-state">
  <h1>Welcome to tickets_please</h1>
  <p class="subtitle">No projects are mounted on this server yet. Mount one to get started — humans and LLM agents will share the same audit trail.</p>
  <div class="page-actions">
    <a class="btn btn-primary" href="/p/new">Create a new project</a>
    <a class="btn" href="/p/load">Load an existing project</a>
  </div>
  <p class="footnote">
    Or run <code>tickets_please mcp</code> from a repo containing a
    <code>.tickets_please/project.yaml</code> to bind a session and have
    the project appear in the sidebar.
  </p>
</section>
{{end}}
