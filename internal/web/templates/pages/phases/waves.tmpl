{{define "main"}}
{{- $proj := .Body.Project -}}
{{- $phases := .Body.Phases -}}
{{- $rows := .Body.Rows -}}
<section class="waves-page">
  <header class="page-header">
    <a class="back-link" href="/p/{{$proj.Slug}}">{{$proj.Name}}</a>
    <h1>Waves</h1>
    <p class="subtitle">Soft integer groupings across the whole project. Wave 0 (unassigned) sorts last.</p>
    <div class="page-actions">
      <a class="btn" href="/p/{{$proj.Slug}}/phases">All phases</a>
    </div>
  </header>

  {{if .Body.Mismatch}}
  <div class="wave-debug-banner" role="alert">
    <strong>Heads up:</strong> the matrix integrity check failed —
    <code>{{.Body.Mismatch}}</code>. Some tickets may reference a phase that no
    longer exists; check the expanded view below for the canonical ticket list.
  </div>
  {{end}}

  {{if .Body.Sections}}
    {{if $rows}}
    <section class="card wave-matrix-card">
      <div class="wave-matrix-scroll">
        <table class="wave-matrix">
          <thead>
            <tr>
              <th class="wave-matrix-corner"></th>
              {{range $phases}}
              <th class="wave-matrix-phase">
                <a href="/p/{{$proj.Slug}}/phases/{{.Slug}}">{{.Name}}</a>
              </th>
              {{end}}
              <th class="wave-matrix-phase wave-matrix-unphased">Unphased</th>
            </tr>
          </thead>
          <tbody>
            {{range $rows}}
            <tr class="wave-matrix-row{{if .IsUnassigned}} muted-section{{end}}">
              <th class="wave-matrix-wave">
                {{if .IsUnassigned}}Wave 0 <span class="muted">(unassigned)</span>{{else}}Wave {{.Wave}}{{end}}
              </th>
              {{range .Cells}}
                {{if eq .Count 0}}
                <td class="wave-cell wave-cell-empty"><span class="muted">—</span></td>
                {{else}}
                <td class="wave-cell">
                  {{if .PhaseSlug}}
                  <a href="/p/{{$proj.Slug}}/phases/{{.PhaseSlug}}" class="wave-cell-link">
                    <span class="wave-cell-count">{{.Count}}</span>
                    <span class="wave-cell-dots">
                      {{if .Dots.Todo}}<span class="dot dot-todo" title="todo: {{.Dots.Todo}}"></span>{{end}}
                      {{if .Dots.InProgress}}<span class="dot dot-in_progress" title="in progress: {{.Dots.InProgress}}"></span>{{end}}
                      {{if .Dots.Testing}}<span class="dot dot-testing" title="testing: {{.Dots.Testing}}"></span>{{end}}
                      {{if .Dots.Done}}<span class="dot dot-done" title="done: {{.Dots.Done}}"></span>{{end}}
                    </span>
                  </a>
                  {{else}}
                  <span class="wave-cell-link wave-cell-static">
                    <span class="wave-cell-count">{{.Count}}</span>
                    <span class="wave-cell-dots">
                      {{if .Dots.Todo}}<span class="dot dot-todo" title="todo: {{.Dots.Todo}}"></span>{{end}}
                      {{if .Dots.InProgress}}<span class="dot dot-in_progress" title="in progress: {{.Dots.InProgress}}"></span>{{end}}
                      {{if .Dots.Testing}}<span class="dot dot-testing" title="testing: {{.Dots.Testing}}"></span>{{end}}
                      {{if .Dots.Done}}<span class="dot dot-done" title="done: {{.Dots.Done}}"></span>{{end}}
                    </span>
                  </span>
                  {{end}}
                </td>
                {{end}}
              {{end}}
            </tr>
            {{end}}
          </tbody>
        </table>
      </div>
      <p class="wave-matrix-legend">
        <span class="dot dot-todo"></span> todo
        <span class="dot dot-in_progress"></span> in progress
        <span class="dot dot-testing"></span> testing
        <span class="dot dot-done"></span> done
      </p>
    </section>
    {{end}}

    <details class="wave-expanded"{{if not $rows}} open{{end}}>
      <summary class="wave-expanded-summary">
        {{if $rows}}Show ticket lists per wave{{else}}Per-wave ticket lists{{end}}
      </summary>
      <div class="wave-expanded-body">
        {{range .Body.Sections}}
        <section class="card wave-section{{if .IsUnassigned}} muted-section{{end}}">
          <h2>
            {{if .IsUnassigned}}Wave 0 <span class="muted">(unassigned)</span>{{else}}Wave {{.Wave}}{{end}}
            <span class="muted">— {{len .Tickets}} ticket{{if ne (len .Tickets) 1}}s{{end}}</span>
          </h2>
          <ul class="bare-list">
            {{range .Tickets}}
            <li>
              <a href="/tickets/{{.ID}}?slug={{$proj.Slug}}">{{.Title}}</a>
              <span class="badge badge-{{.Column}}">{{.Column}}</span>
              {{if .PhaseID}}<span class="muted">— phase {{.PhaseID}}</span>{{end}}
            </li>
            {{end}}
          </ul>
        </section>
        {{end}}
      </div>
    </details>
  {{else}}
  <div class="empty-state">
    <h1>No tickets yet</h1>
    <p class="subtitle">Create some tickets and they'll show up here grouped by their wave number.</p>
    <div class="page-actions">
      <a class="btn btn-primary" href="/p/{{$proj.Slug}}/tickets/new">New ticket</a>
    </div>
  </div>
  {{end}}
</section>
{{end}}
