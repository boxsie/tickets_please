{{define "main"}}
{{- $b := .Body -}}
{{- $proj := $b.Project -}}
{{- $phase := $b.Phase -}}
<section class="phase-summary">
  <header class="page-header">
    <a class="back-link" href="/p/{{$proj.Slug}}/phases/{{$phase.Slug}}">{{$phase.Name}}</a>
    <h1>{{$phase.Name}} <span class="muted">· summary</span></h1>
  </header>

  <div id="summary-region">
    {{if eq $b.Mode "edit"}}
      {{template "phase_summary_edit.tmpl" $b}}
    {{else}}
      {{template "phase_summary_view.tmpl" $b}}
    {{end}}
  </div>
</section>
{{end}}
