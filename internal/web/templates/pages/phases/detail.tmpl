{{define "main"}}
{{- $proj := .Body.Project -}}
{{- $phase := .Body.Phase -}}
<section class="phase-detail">
  <header class="page-header">
    <a class="back-link" href="/p/{{$proj.Slug}}/phases">All phases</a>
    <h1>{{$phase.Name}}</h1>
    <p class="subtitle">
      <code>{{$phase.Slug}}</code>
      {{if $phase.Description}}<span class="breadcrumb-sep"></span>{{$phase.Description}}{{end}}
      <span class="breadcrumb-sep"></span>
      {{$phase.ActiveTicketCount}} active / {{$phase.TicketCount}} total
    </p>
    <div class="page-actions">
      <a class="btn btn-primary" href="/p/{{$proj.Slug}}/phases/{{$phase.Slug}}/summary">Summary</a>
      <a class="btn" href="/p/{{$proj.Slug}}/phases/{{$phase.Slug}}/edit">Edit</a>
    </div>
  </header>

  <section class="card">
    <h2>Summary</h2>
    {{if $phase.Summary}}
    <div class="markdown">{{markdown $phase.Summary}}</div>
    <p style="margin-top: 1rem;"><a href="/p/{{$proj.Slug}}/phases/{{$phase.Slug}}/summary">Open the full summary editor →</a></p>
    {{else}}
    <p class="hint">No summary set. <a href="/p/{{$proj.Slug}}/phases/{{$phase.Slug}}/summary?edit=1">Add one →</a></p>
    {{end}}
  </section>

  {{if .Body.Waves}}
  <div class="phase-row-waves phase-detail-waves">
    {{range .Body.Waves}}
    <section class="phase-wave{{if .IsUnassigned}} muted-section{{end}}">
      <header class="phase-wave-head">
        <span class="phase-wave-chip{{if .IsUnassigned}} phase-wave-chip-unassigned{{end}}">
          {{if .IsUnassigned}}W0{{else}}W{{.Wave}}{{end}}
        </span>
        <span class="phase-wave-title">
          {{if .IsUnassigned}}Unassigned wave{{else}}Wave {{.Wave}}{{end}}
        </span>
        <span class="phase-wave-count muted">{{len .Tickets}} ticket{{if ne (len .Tickets) 1}}s{{end}}</span>
      </header>
      <ul class="phase-wave-tickets">
        {{range .Tickets}}
        <li class="phase-wave-ticket">
          <span class="dot dot-{{.Column}}" title="{{.Column}}"></span>
          <a class="phase-wave-ticket-title" href="/tickets/{{.ID}}?slug={{$proj.Slug}}">{{.Title}}</a>
          <span class="badge badge-{{.Column}}">{{.Column}}</span>
        </li>
        {{end}}
      </ul>
    </section>
    {{end}}
  </div>
  {{else}}
  <div class="phase-row-empty">
    <p class="hint">No tickets in this phase yet.</p>
    <a class="btn btn-sm" href="/p/{{$proj.Slug}}/tickets/new">+ New ticket</a>
  </div>
  {{end}}

  <details class="danger-zone">
    <summary>Delete phase</summary>
    <p class="hint">
      Removes phase <code>{{$phase.Slug}}</code>. Refuses if any ticket is
      still attached. Cannot be undone.
    </p>
    <form method="post" action="/p/{{$proj.Slug}}/phases/{{$phase.Slug}}/delete" onsubmit="return confirm('Delete phase {{$phase.Slug}}? Tickets must be reassigned or deleted first.');">
      <input type="hidden" name="_csrf" value="{{.Chrome.CSRF}}">
      <input type="hidden" name="confirm" value="yes">
      <button type="submit" class="btn btn-danger">Delete this phase</button>
    </form>
  </details>
</section>
{{end}}
