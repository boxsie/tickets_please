{{define "main"}}
{{- $f := .Body -}}
{{- $proj := $f.Project -}}
{{- $tkt := $f.Ticket -}}
<section class="form-page">
  <header class="page-header">
    <a class="back-link" href="/tickets/{{$tkt.ID}}?slug={{$proj.Slug}}">{{$tkt.Title}}</a>
    <h1>Edit ticket</h1>
    <p class="subtitle">Phase + dependencies are edited via the action panel on the detail page.</p>
  </header>
  {{if $f.FormError}}<div class="form-error" role="alert"><strong>Error:</strong> {{$f.FormError}}</div>{{end}}
  <form method="post" action="/tickets/{{$tkt.ID}}?slug={{$proj.Slug}}" class="stack">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" required value="{{$f.Submitted.Title}}">

    <label for="body">Body <span class="muted">(markdown)</span></label>
    <textarea id="body" name="body" rows="14">{{$f.Submitted.Body}}</textarea>

    <label for="wave">Wave</label>
    <input type="number" id="wave" name="wave" min="0" value="{{$f.Submitted.Wave}}">

    <input type="hidden" name="_csrf" value="{{.Chrome.CSRF}}">
    <div class="form-actions">
      <button type="submit">Save</button>
      <a class="btn-link" href="/tickets/{{$tkt.ID}}?slug={{$proj.Slug}}">Cancel</a>
    </div>
  </form>
</section>
{{end}}
