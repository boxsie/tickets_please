{{define "main"}}
{{- $f := .Body -}}
{{- $proj := $f.Project -}}
<section class="form-page">
  <header class="page-header">
    <h1>New ticket <span class="muted">· {{$proj.Name}}</span></h1>
    <p class="hint">
      New tickets land in <code>todo</code>. Wave 0 means "unassigned" — leave
      it 0 unless this work belongs to a specific wave inside its phase.
    </p>
  </header>
  {{if $f.FormError}}<div class="form-error" role="alert"><strong>Error:</strong> {{$f.FormError}}</div>{{end}}
  <form method="post" action="/p/{{$proj.Slug}}/tickets" class="stack">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" required value="{{$f.Submitted.Title}}" placeholder="What needs doing?">

    <label for="body">Body <span class="muted">(markdown)</span></label>
    <textarea id="body" name="body" rows="14" placeholder="Goal, scope, constraints, key files. Markdown welcome.">{{$f.Submitted.Body}}</textarea>

    {{if $f.Phases}}
    <label for="phase">Phase <span class="muted">(optional)</span></label>
    <select id="phase" name="phase">
      <option value="">— no phase —</option>
      {{range $f.Phases}}
      <option value="{{.Slug}}"{{if eq .Slug $f.Submitted.PhaseSlug}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
    {{end}}

    <label for="wave">Wave <span class="muted">(integer, 0 = unassigned)</span></label>
    <input type="number" id="wave" name="wave" min="0" value="{{$f.Submitted.Wave}}">

    <label for="depends_on">Depends on <span class="muted">(ticket ids, comma-separated)</span></label>
    <input type="text" id="depends_on_inline" name="depends_on_inline"
           placeholder="abcd-1234, efgh-5678"
           value="{{range $i, $d := $f.Submitted.DependsOn}}{{if $i}}, {{end}}{{$d}}{{end}}">

    <label for="parallelizable_with_inline">Parallelizable with <span class="muted">(ticket ids, comma-separated)</span></label>
    <input type="text" id="parallelizable_with_inline" name="parallelizable_with_inline"
           placeholder="abcd-1234, efgh-5678"
           value="{{range $i, $p := $f.Submitted.Parallelizable}}{{if $i}}, {{end}}{{$p}}{{end}}">

    <input type="hidden" name="_csrf" value="{{.Chrome.CSRF}}">
    <div class="form-actions">
      <button type="submit">Create ticket</button>
      <a class="btn-link" href="/p/{{$proj.Slug}}/board">Cancel</a>
    </div>
  </form>
</section>
{{end}}
