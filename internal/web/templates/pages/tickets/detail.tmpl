{{define "main"}}
{{- $b := .Body -}}
{{- $proj := $b.Project -}}
{{- $tkt := $b.Ticket -}}
{{- $phase := $b.Phase -}}
<section class="ticket-detail">
  <header class="page-header">
    <h1>{{$tkt.Title}}</h1>
    <p class="muted">
      <a href="/p/{{$proj.Slug}}/board">{{$proj.Name}}</a>
      {{if $phase}}· <a href="/p/{{$proj.Slug}}/phases/{{$phase.Slug}}">{{$phase.Name}}</a>{{else}}· <span class="muted">no phase</span>{{end}}
      · <span class="badge badge-{{$tkt.Column}}">{{$tkt.Column}}</span>
      {{if ne $tkt.Wave 0}}· wave {{$tkt.Wave}}{{end}}
      · id <code>{{$tkt.ID}}</code>
    </p>
    <p class="page-actions">
      {{if $b.IsDone}}
        {{template "frozen_actions.tmpl" $b}}
      {{else}}
        <a class="btn" href="/tickets/{{$tkt.ID}}/edit?slug={{$proj.Slug}}">Edit</a>
      {{end}}
    </p>
  </header>

  <section class="card">
    <h2>Body</h2>
    {{if $tkt.Body}}
    <div class="markdown">{{markdown $tkt.Body}}</div>
    {{else}}
    <p class="hint">No body.</p>
    {{end}}
  </section>

  {{if or $tkt.DependsOn $tkt.ParallelizableWith $b.Blocks}}
  <section class="card">
    <h2>Dependencies</h2>
    {{if $b.Depends}}
    <p><strong>Depends on:</strong></p>
    <ul class="bare-list">
      {{range $b.Depends}}
      <li><a href="/tickets/{{.ID}}?slug={{$proj.Slug}}">{{.Title}}</a> <span class="badge badge-{{.Column}}">{{.Column}}</span></li>
      {{end}}
    </ul>
    {{end}}
    {{if $b.Blocks}}
    <p><strong>Blocks:</strong></p>
    <ul class="bare-list">
      {{range $b.Blocks}}
      <li><a href="/tickets/{{.ID}}?slug={{$proj.Slug}}">{{.Title}}</a> <span class="badge badge-{{.Column}}">{{.Column}}</span></li>
      {{end}}
    </ul>
    {{end}}
  </section>
  {{end}}

  {{if $b.IsDone}}
  <section class="card frozen-card">
    <h2>Completion</h2>
    {{if $tkt.TestingEvidence}}<details open><summary>Testing evidence</summary><div class="markdown">{{markdown (deref $tkt.TestingEvidence)}}</div></details>{{end}}
    {{if $tkt.WorkSummary}}<details><summary>Work summary</summary><div class="markdown">{{markdown (deref $tkt.WorkSummary)}}</div></details>{{end}}
    {{if $tkt.Learnings}}<details><summary>Learnings</summary><div class="markdown">{{markdown (deref $tkt.Learnings)}}</div></details>{{end}}
  </section>
  {{else}}
  <section class="card">
    <h2>Move</h2>
    {{template "move_form.tmpl" $b}}
  </section>

  <section class="card">
    <h2>Complete</h2>
    {{template "complete_form.tmpl" $b}}
  </section>

  {{if $b.Phases}}
  <section class="card">
    <h2>Reassign phase</h2>
    {{template "assign_phase_form.tmpl" (mkAssignPhase $tkt.ID $proj.Slug (phaseSlug $tkt $b.Phases) $b.Phases $b.CSRF)}}
  </section>
  {{end}}
  {{end}}

  {{template "comments_thread.tmpl" $b.Comments}}
</section>
{{end}}
