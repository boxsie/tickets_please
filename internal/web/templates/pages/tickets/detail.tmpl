{{define "main"}}
{{- $b := .Body -}}
{{- $proj := $b.Project -}}
{{- $tkt := $b.Ticket -}}
{{- $phase := $b.Phase -}}
<section class="ticket-detail">
  <header class="page-header">
    <h1>{{$tkt.Title}}</h1>
    <p class="ticket-meta">
      <a href="/p/{{$proj.Slug}}/board">{{$proj.Name}}</a>
      <span class="breadcrumb-sep"></span>
      {{if $phase}}<a href="/p/{{$proj.Slug}}/phases/{{$phase.Slug}}">{{$phase.Name}}</a>{{else}}<span class="muted">no phase</span>{{end}}
      <span class="breadcrumb-sep"></span>
      <span class="badge badge-{{$tkt.Column}}">{{$tkt.Column}}</span>
      {{if ne $tkt.Wave 0}}<span class="breadcrumb-sep"></span>wave {{$tkt.Wave}}{{end}}
      <span class="breadcrumb-sep"></span>
      <span class="id-pill" title="{{$tkt.ID}}">{{slice $tkt.ID 0 8}}</span>
    </p>
    <div class="page-actions">
      {{if $b.IsDone}}
        {{template "frozen_actions.tmpl" $b}}
      {{else}}
        <button type="button" class="btn btn-primary" data-dialog="dlg-complete">Complete</button>
        <button type="button" class="btn" data-dialog="dlg-move">Move</button>
        {{if $b.Phases}}<button type="button" class="btn" data-dialog="dlg-assign-phase">Reassign phase</button>{{end}}
        <a class="btn" href="/tickets/{{$tkt.ID}}/edit?slug={{$proj.Slug}}">Edit ticket</a>
        <button type="button" class="btn btn-danger" data-dialog="dlg-delete">Delete</button>
      {{end}}
    </div>
  </header>

  <div class="ticket-main">
    <section class="card">
      <h2>Body</h2>
      {{if $tkt.Body}}<div class="markdown">{{markdown $tkt.Body}}</div>{{else}}<p class="hint">No body.</p>{{end}}
    </section>

    {{if or $tkt.DependsOn $b.Blocks}}
    <section class="card">
      <h2>Dependencies</h2>
      {{if $b.Depends}}
      <p><strong>Depends on</strong></p>
      <ul class="bare-list">
        {{range $b.Depends}}<li><a href="/tickets/{{.ID}}?slug={{$proj.Slug}}">{{.Title}}</a> <span class="badge badge-{{.Column}}">{{.Column}}</span></li>{{end}}
      </ul>
      {{end}}
      {{if $b.Blocks}}
      <p><strong>Blocks</strong></p>
      <ul class="bare-list">
        {{range $b.Blocks}}<li><a href="/tickets/{{.ID}}?slug={{$proj.Slug}}">{{.Title}}</a> <span class="badge badge-{{.Column}}">{{.Column}}</span></li>{{end}}
      </ul>
      {{end}}
    </section>
    {{end}}

    {{if $b.IsDone}}
    <section class="card frozen-card">
      <h2>Completion</h2>
      {{if $tkt.TestingEvidence}}<details open><summary>Testing evidence</summary><div class="markdown">{{markdown (deref $tkt.TestingEvidence)}}</div></details>{{end}}
      {{if $tkt.WorkSummary}}<details><summary>Work summary</summary><div class="markdown">{{markdown (deref $tkt.WorkSummary)}}</div></details>{{end}}
      {{if $tkt.Learnings}}<details><summary>Learnings</summary><div class="markdown">{{markdown (deref $tkt.Learnings)}}</div></details>{{end}}
    </section>
    {{end}}

    {{template "comments_thread.tmpl" $b.Comments}}
  </div>

  {{if not $b.IsDone}}
  <dialog id="dlg-move" class="modal">
    <div class="modal-header">
      <h2>Move ticket</h2>
      <form method="dialog"><button type="submit" class="btn modal-close" aria-label="Close">×</button></form>
    </div>
    <div class="modal-body">
      {{template "move_form.tmpl" $b}}
    </div>
  </dialog>

  <dialog id="dlg-complete" class="modal modal-wide">
    <div class="modal-header">
      <h2>Complete ticket</h2>
      <form method="dialog"><button type="submit" class="btn modal-close" aria-label="Close">×</button></form>
    </div>
    <div class="modal-body">
      {{template "complete_form.tmpl" $b}}
    </div>
  </dialog>

  {{if $b.Phases}}
  <dialog id="dlg-assign-phase" class="modal">
    <div class="modal-header">
      <h2>Reassign phase</h2>
      <form method="dialog"><button type="submit" class="btn modal-close" aria-label="Close">×</button></form>
    </div>
    <div class="modal-body">
      {{template "assign_phase_form.tmpl" (mkAssignPhase $tkt.ID $proj.Slug (phaseSlug $tkt $b.Phases) $b.Phases $b.CSRF)}}
    </div>
  </dialog>
  {{end}}

  <dialog id="dlg-delete" class="modal">
    <div class="modal-header">
      <h2>Delete ticket</h2>
      <form method="dialog"><button type="submit" class="btn modal-close" aria-label="Close">×</button></form>
    </div>
    <div class="modal-body">
      <p>This will <strong>permanently remove</strong> &ldquo;{{$tkt.Title}}&rdquo;, including its body, comments, and embeddings. This cannot be undone.</p>
      <p class="hint">Any other tickets that reference this one in <code>depends_on</code> or <code>parallelizable_with</code> will be auto-updated to drop the reference. Tickets in <code>done</code> can never be deleted (completion is sacred).</p>
      <form method="post" action="/tickets/{{$tkt.ID}}/delete?slug={{$proj.Slug}}" class="stack">
        <input type="hidden" name="_csrf" value="{{$b.CSRF}}">
        <div class="form-actions">
          <button type="submit" class="btn-danger">Delete forever</button>
          <button type="button" class="btn" data-dialog-close="dlg-delete">Cancel</button>
        </div>
      </form>
    </div>
  </dialog>

  <script>
    (function () {
      document.querySelectorAll('[data-dialog]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var dlg = document.getElementById(btn.getAttribute('data-dialog'));
          if (dlg && typeof dlg.showModal === 'function') dlg.showModal();
        });
      });
      document.querySelectorAll('[data-dialog-close]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var dlg = document.getElementById(btn.getAttribute('data-dialog-close'));
          if (dlg) dlg.close();
        });
      });
      document.querySelectorAll('dialog.modal').forEach(function (dlg) {
        dlg.addEventListener('click', function (e) {
          if (e.target === dlg) dlg.close();
        });
      });
    })();
  </script>
  {{end}}
</section>
{{end}}
