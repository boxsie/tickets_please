{{define "main"}}
{{- $f := .Body -}}
<section class="logs-page">
  <header class="page-header">
    <h1>Server logs</h1>
    <p class="subtitle">
      Structured log records, JSON-encoded, oldest first. Mirrors what the operator sees on stderr.
    </p>
    <p class="muted">Auto-tailing every 2 seconds (in-page htmx swap; no full reload).</p>
  </header>
  {{template "logs_pre.tmpl" $f}}
</section>
{{end}}
