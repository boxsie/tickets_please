{{define "main"}}
{{- $f := .Body -}}
<section class="settings-page">
  <header class="page-header">
    <h1>Server settings</h1>
    <p class="subtitle">
      Defaults for <em>new</em> projects, plus shared transport bits like the Ollama URL.
      Existing projects pin their own embedder in <code>project.yaml</code> — flip those via per-project Settings.
    </p>
    <p class="muted">
      Edits write to <code>{{$f.ConfigPath}}</code> and preserve any comments in that file.
      Loaded from: <code>{{$f.ConfigSource}}</code>.
    </p>
  </header>

  {{if $f.FormError}}<div class="form-error" role="alert"><strong>Error:</strong> {{$f.FormError}}</div>{{end}}

  <form method="post" action="/settings" class="stack settings-form">
    <fieldset class="settings-section">
      <legend>Embedding defaults</legend>
      <p class="hint">Used when registering a new project. Existing mounts keep whatever they pinned in <code>project.yaml</code>.</p>

      <label for="embed_provider">Default embed provider</label>
      <select id="embed_provider" name="embed_provider">
        <option value="ollama" {{if eq $f.EmbedProvider "ollama"}}selected{{end}}>ollama</option>
        <option value="openai" {{if eq $f.EmbedProvider "openai"}}selected{{end}}>openai</option>
      </select>

      <label for="embed_model">Default embed model</label>
      <input type="text" id="embed_model" name="embed_model" value="{{$f.EmbedModel}}" placeholder="nomic-embed-text">
    </fieldset>

    <fieldset class="settings-section">
      <legend>Provider transport</legend>
      <p class="hint">Where this server reaches out to talk to its embedders.</p>

      <label for="ollama_url">Ollama URL</label>
      <input type="text" id="ollama_url" name="ollama_url" value="{{$f.OllamaURL}}" placeholder="http://localhost:11434">

      <label for="openai_api_key">
        OpenAI API key
        {{if $f.KeyMasked}}<span class="badge-inline">currently set — type to overwrite</span>{{end}}
      </label>
      <input type="password" id="openai_api_key" name="openai_api_key"
        placeholder="{{if $f.KeyMasked}}••••••••{{else}}sk-…{{end}}"
        autocomplete="off">
    </fieldset>

    <input type="hidden" name="_csrf" value="{{.Chrome.CSRF}}">
    <div class="form-actions">
      <button type="submit">Save settings</button>
    </div>
  </form>

  <section class="settings-readonly" aria-label="Storage paths">
    <h2>Storage</h2>
    <p class="hint">Read-only — set via <code>config.yaml</code> or environment variables.</p>
    <dl class="kv-list">
      <dt>Per-repo data dir</dt>
      <dd><code>{{$f.DataDir}}</code><span class="kv-aside">project content checked into each repo</span></dd>

      <dt>Shared data root</dt>
      <dd><code>{{$f.DataRoot}}</code><span class="kv-aside">cross-repo agent + mount cache</span></dd>
    </dl>
  </section>

  <section class="settings-mounts">
    <h2>Mounted projects</h2>
    <p class="hint">Currently mounted projects with their per-project embedder. Re-embed rebuilds that project's index.</p>
    {{if $f.Mounts}}
    <table class="data-table">
      <thead>
        <tr>
          <th>Project</th>
          <th>Embed provider</th>
          <th>Embed model</th>
          <th>Dim</th>
          <th class="ra">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{range $f.Mounts}}
        <tr>
          <td><a href="/p/{{.Slug}}">{{.Slug}}</a></td>
          <td>{{.EmbedName}}</td>
          <td><code>{{.EmbedModel}}</code></td>
          <td>{{.EmbedDim}}</td>
          <td class="ra">
            <form method="post" action="/p/{{.Slug}}/reembed" class="inline-form">
              <input type="hidden" name="_csrf" value="{{$.Chrome.CSRF}}">
              <button type="submit" class="btn-link">Re-embed</button>
            </form>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
    <form method="post" action="/settings/reembed-all" class="inline-form mounts-bulk">
      <input type="hidden" name="_csrf" value="{{.Chrome.CSRF}}">
      <button type="submit" class="btn">Re-embed all projects</button>
      <span class="hint">Useful after switching the default embed model.</span>
    </form>
    {{else}}
    <p class="muted">No projects mounted yet.</p>
    {{end}}
  </section>
</section>
{{end}}
