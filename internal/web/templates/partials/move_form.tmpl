{{define "move_form.tmpl"}}{{- $tkt := .Ticket -}}{{- $proj := .Project -}}<form method="post" action="/tickets/{{$tkt.ID}}/move?slug={{$proj.Slug}}" class="stack">
  <label for="target_column">Target column</label>
  <select id="target_column" name="target_column" required>
    {{if ne (printf "%s" $tkt.Column) "todo"}}<option value="todo">todo</option>{{end}}
    {{if ne (printf "%s" $tkt.Column) "in_progress"}}<option value="in_progress">in_progress</option>{{end}}
    {{if ne (printf "%s" $tkt.Column) "testing"}}<option value="testing">testing</option>{{end}}
  </select>
  <label for="move-comment">Comment <span class="muted">(required)</span></label>
  <textarea id="move-comment" name="comment" rows="2" required minlength="1" placeholder="Why are you moving this?"></textarea>
  <input type="hidden" name="_csrf" value="{{.CSRF}}">
  <div class="form-actions">
    <button type="submit">Move</button>
  </div>
  <p class="hint m-0">Use <strong>Complete</strong> below to mark done — that's the only path.</p>
</form>
{{end}}
