{{define "fs_picker.tmpl"}}<div id="picker" class="fs-picker">
  <nav class="fs-breadcrumb" aria-label="Current path">
    {{range $i, $c := .Crumbs}}
      {{if $i}}<span class="fs-sep">›</span>{{end}}
      <a href="#" hx-get="/api/fs?path={{$c.Path}}" hx-target="#picker" hx-swap="outerHTML">{{$c.Label}}</a>
    {{end}}
  </nav>

  <div class="fs-actions">
    <input type="hidden" name="path" value="{{.Cwd}}" form="load-form">
    {{if .HasMarker}}
    <button type="submit" form="load-form" class="btn-primary">Load this directory</button>
    <span class="hint marker-hint">✓ this directory contains a tickets_please project</span>
    {{else}}
    <button type="submit" form="load-form" class="btn" disabled title="Pick a directory containing .tickets_please/project.yaml">Load this directory</button>
    <span class="hint">Navigate into a folder marked <span class="marker-badge inline-badge">project</span> to enable.</span>
    {{end}}
  </div>

  {{if .Error}}
  <div class="form-error" role="alert"><strong>{{.Error}}</strong></div>
  {{else}}
  <ul class="fs-listing">
    {{if .Parent}}
    <li class="fs-row">
      <a href="#" hx-get="/api/fs?path={{.Parent}}" hx-target="#picker" hx-swap="outerHTML">..</a>
      <span class="muted">parent</span>
    </li>
    {{end}}
    {{range .Entries}}
    <li class="fs-row{{if .HasMarker}} fs-row-marker{{end}}">
      <a href="#" hx-get="/api/fs?path={{$.Cwd}}/{{.Name}}" hx-target="#picker" hx-swap="outerHTML">{{.Name}}/</a>
      {{if .HasMarker}}<span class="marker-badge">project</span>{{end}}
    </li>
    {{else}}
    {{if not .Parent}}{{else}}<li class="fs-empty muted">— no subdirectories —</li>{{end}}
    {{end}}
    {{if .Truncated}}<li class="fs-empty muted">More than 500 entries — listing truncated.</li>{{end}}
  </ul>
  {{end}}
</div>
{{end}}
