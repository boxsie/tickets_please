{{define "complete_form.tmpl"}}{{- $tkt := .Ticket -}}{{- $proj := .Project -}}<form method="post" action="/tickets/{{$tkt.ID}}/complete?slug={{$proj.Slug}}" class="stack">
  <label for="testing_evidence">Testing evidence <span class="muted">(≥10 chars; what you tested and how)</span></label>
  <textarea id="testing_evidence" name="testing_evidence" rows="4" required minlength="10"></textarea>

  <label for="work_summary">Work summary <span class="muted">(≥10 chars; what you actually changed)</span></label>
  <textarea id="work_summary" name="work_summary" rows="4" required minlength="10"></textarea>

  <label for="learnings">Learnings <span class="muted">(≥10 chars; gotchas and insights for future work — these are searchable)</span></label>
  <textarea id="learnings" name="learnings" rows="4" required minlength="10"></textarea>

  <input type="hidden" name="_csrf" value="{{.CSRF}}">
  <div class="form-actions">
    <button type="submit" class="btn-primary">Complete ticket</button>
  </div>
  <p class="hint">Once complete, the ticket is frozen — no edits, no reopen. If new work surfaces, create a new ticket.</p>
</form>
{{end}}
