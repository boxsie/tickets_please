{{define "assign_phase_form.tmpl"}}<form method="post"
      action="/tickets/{{.TicketID}}/assign-phase{{if .ProjectSlug}}?slug={{.ProjectSlug}}{{end}}"
      class="stack assign-phase-form">
  <label for="phase">Phase</label>
  <select id="phase" name="phase">
    <option value="">— no phase —</option>
    {{range .Phases}}
    <option value="{{.Slug}}"{{if eq .Slug $.CurrentPhaseSlug}} selected{{end}}>{{.Name}}</option>
    {{end}}
  </select>
  <label for="assign-comment">Comment <span class="muted">(required — captures the why)</span></label>
  <textarea id="assign-comment" name="comment" rows="3" required></textarea>
  <input type="hidden" name="_csrf" value="{{.CSRF}}">
  <div class="form-actions">
    <button type="submit">Reassign</button>
  </div>
</form>
{{end}}
