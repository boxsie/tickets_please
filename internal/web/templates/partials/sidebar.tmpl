{{define "sidebar.tmpl"}}{{- /*
  The sidebar wires itself to a body-scoped htmx event so handlers that mutate
  the project set (POST /p, POST /p/load, POST /p/{slug}/delete) can refresh
  just the rail by emitting `HX-Trigger: sidebar-refresh`.

  hx-get points at /_partials/sidebar (a dedicated handler that always
  returns just the sidebar fragment, irrespective of HX-Request semantics) so
  the swap is self-contained.
*/ -}}
<aside
  id="sidebar"
  class="sidebar"
  hx-get="/_partials/sidebar"
  hx-trigger="sidebar-refresh from:body"
  hx-swap="outerHTML"
>
  <h2 class="sidebar-heading">Projects</h2>
  {{if .Chrome.Projects}}
  <ul class="sidebar-list">
    {{- $cur := .CurrentSlug -}}
    {{range .Chrome.Projects}}
    <li>
      <a
        href="/p/{{.Slug}}"
        class="sidebar-link{{if eq .Slug $cur}} is-active{{end}}"
        {{- if eq .Slug $cur}} aria-current="page"{{end}}
      >{{.Name}}</a>
    </li>
    {{end}}
  </ul>
  {{else}}
  <p class="sidebar-empty">No projects mounted.</p>
  {{end}}
  <nav class="sidebar-actions" aria-label="Project actions">
    <a class="sidebar-action" href="/p/load">[+] Load existing project</a>
    <a class="sidebar-action" href="/p/new">[+] New project</a>
  </nav>
</aside>
{{end}}
