{{define "sidebar.tmpl"}}{{- /*
  Sidebar: project picker (combobox) + per-project nav.

  The picker is the switcher; clicking the toggle reveals a search input,
  filterable list, and "+ New project" / "+ Load existing" actions. The
  per-project nav below is rendered only when the user is "inside" a
  project (CurrentSlug matches a known project) and gives access to every
  project view from anywhere in the app.

  The whole rail re-fetches itself from /_partials/sidebar on the
  body-scoped `sidebar-refresh` event — handlers that mutate the project
  set emit that via HX-Trigger so the picker stays in sync.
*/ -}}
<aside
  id="sidebar"
  class="sidebar"
  hx-get="/_partials/sidebar"
  hx-trigger="sidebar-refresh from:body"
  hx-swap="outerHTML"
>
  {{template "project_picker.tmpl" .}}

  {{- $cur := .CurrentSlug -}}
  {{- $url := .Chrome.URL -}}
  {{- $active := "" -}}
  {{- range .Chrome.Projects -}}{{if eq .Slug $cur}}{{$active = .}}{{end}}{{- end -}}

  {{if $active}}
  <nav class="project-nav" aria-label="{{$active.Name}} navigation">
    <h2 class="sidebar-heading">{{$active.Name}}</h2>
    {{$overview := printf "/p/%s" $cur}}
    <a class="project-nav-link{{if eq $url $overview}} active{{end}}" href="{{$overview}}"{{if eq $url $overview}} aria-current="page"{{end}}>Overview</a>
    <a class="project-nav-link{{if hasSuffix $url "/board"}} active{{end}}" href="/p/{{$cur}}/board"{{if hasSuffix $url "/board"}} aria-current="page"{{end}}>Board</a>
    <a class="project-nav-link{{if hasSuffix $url "/phases"}} active{{end}}" href="/p/{{$cur}}/phases"{{if hasSuffix $url "/phases"}} aria-current="page"{{end}}>Phases</a>
    <a class="project-nav-link{{if hasSuffix $url "/summary"}} active{{end}}" href="/p/{{$cur}}/summary"{{if hasSuffix $url "/summary"}} aria-current="page"{{end}}>Summary</a>
    <hr class="project-nav-sep">
    <a class="project-nav-cta{{if hasSuffix $url "/tickets/new"}} active{{end}}" href="/p/{{$cur}}/tickets/new"{{if hasSuffix $url "/tickets/new"}} aria-current="page"{{end}}>+ New ticket</a>
    <a class="project-nav-link muted{{if hasSuffix $url "/settings"}} active{{end}}" href="/p/{{$cur}}/settings"{{if hasSuffix $url "/settings"}} aria-current="page"{{end}}>Settings</a>
  </nav>
  {{else}}
  <p class="sidebar-empty">No project selected. Pick one from the dropdown above or create a new one.</p>
  {{end}}
</aside>
{{end}}
