{{define "comment.tmpl"}}{{- $c := .Comment -}}<li id="comment-{{$c.ID}}" class="comment-row{{if .IsSystem}} comment-system{{end}}">
  <div class="comment-meta">
    <span class="comment-author">{{.AuthorLabel}}</span>
    {{if .IsSystem}}<span class="badge badge-system" title="generated by the server on a column move or completion">system</span>{{end}}
    {{if and $c.FromColumn $c.ToColumn}}<span class="muted">{{derefCol $c.FromColumn}} → {{derefCol $c.ToColumn}}</span>{{end}}
    <time datetime="{{$c.CreatedAt.Format "2006-01-02T15:04:05Z07:00"}}" title="{{$c.CreatedAt.Format "2006-01-02 15:04:05 MST"}}">{{$c.CreatedAt.Format "2006-01-02 15:04"}}</time>
  </div>
  {{if $c.Body}}<div class="comment-body markdown">{{markdown $c.Body}}</div>{{end}}
</li>
{{end}}
