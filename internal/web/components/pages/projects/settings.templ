package projects

import (
	"strconv"

	"tickets_please/internal/web/components/ui"
)

// Settings is the consolidated project settings page (1:1 port of
// templates/pages/projects/settings.tmpl). Embedding-status panel + name /
// description / embed_provider / embed_model edits + re-embed trigger.
// Form widgets use the @ui.Label / @ui.Input / @ui.Select primitives so the
// component library carries the styling.
templ Settings(props SettingsProps) {
	{{ p := props.Project }}
	{{ s := props.Status }}
	<section class="form-page">
		<header class="page-header">
			<h1>{ p.Name } · settings</h1>
			<p class="subtitle">
				Slug <code>{ p.Slug }</code> is immutable.
				Edit the long-form summary on the <a href={ templ.SafeURL("/p/" + p.Slug + "/summary") }>Summary page</a>.
			</p>
		</header>
		@ui.Card(ui.CardProps{Title: "Embedding status", Class: "embedding-status"}) {
			if s.SidecarPresent {
				<p>
					Embedded with <code>{ s.SidecarProvider }/{ s.SidecarModel }</code>
					(<code>{ strconv.Itoa(s.SidecarDim) }d</code>).
					if s.SidecarProvider != s.ExpectedProvider || s.SidecarModel != s.ExpectedModel {
						Project record asks for <code>{ s.ExpectedProvider }/{ s.ExpectedModel }</code> —
						re-embed to bring sidecars in line.
					}
				</p>
			} else {
				<p class="hint">No sidecars yet. Either this project was just created or a re-embed is in flight.</p>
			}
			<form
				method="post"
				action={ templ.SafeURL("/p/" + p.Slug + "/reembed") }
				hx-confirm="This will rebuild all embeddings for this project."
			>
				<input type="hidden" name="_csrf" value={ props.CSRF }/>
				@ui.Button(ui.ButtonProps{Type: "submit", Label: "Re-embed project"})
			</form>
		}
		if props.FormError != "" {
			<div class="form-error" role="alert"><strong>Error:</strong> { props.FormError }</div>
		}
		<form method="post" action={ templ.SafeURL("/p/" + p.Slug + "/settings") } class="stack">
			@ui.Label(ui.LabelProps{For: "name", Text: "Name"})
			@ui.Input(ui.InputProps{ID: "name", Name: "name", Required: true, Value: props.Submitted.Name})
			@ui.Label(ui.LabelProps{For: "description", Text: "Description"})
			@ui.Input(ui.InputProps{ID: "description", Name: "description", Value: props.Submitted.Description})
			@ui.Label(ui.LabelProps{For: "embed_provider", Text: "Embed provider"})
			@ui.Select(ui.SelectProps{
				ID:   "embed_provider",
				Name: "embed_provider",
				Options: []ui.SelectOption{
					{Value: "ollama", Label: "ollama", Selected: props.Submitted.EmbedProvider == "ollama"},
					{Value: "openai", Label: "openai", Selected: props.Submitted.EmbedProvider == "openai"},
				},
			})
			<label for="embed_model">Embed model <span class="muted">(provider-specific identifier)</span></label>
			@ui.Input(ui.InputProps{
				ID:          "embed_model",
				Name:        "embed_model",
				Value:       props.Submitted.EmbedModel,
				Placeholder: "e.g. nomic-embed-text or text-embedding-3-small",
			})
			<input type="hidden" name="_csrf" value={ props.CSRF }/>
			<div class="form-actions">
				@ui.Button(ui.ButtonProps{Type: "submit", Label: "Save settings"})
				<a class="btn-link" href={ templ.SafeURL("/p/" + p.Slug) }>Cancel</a>
			</div>
			<p class="hint">Changing the provider or model triggers a full re-embed automatically.</p>
		</form>
	</section>
}
