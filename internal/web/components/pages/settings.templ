package pages

import "strconv"

// SettingsProps is the typed view-model the Settings page renders. Mirrors
// handlers_settings.go's settingsPageData plus the CSRF token (which the
// legacy template pulled off `.Chrome.CSRF`). The CSRF field is duplicated
// onto the page props rather than read from the layout because templ pages
// take their own typed props directly — no `.Body` bag, no `.Chrome`
// reach-through.
type SettingsProps struct {
	EmbedProvider string
	EmbedModel    string
	OllamaURL     string
	DataDir       string
	DataRoot      string
	ConfigPath    string
	ConfigSource  string
	KeyMasked     bool

	FormError string
	Mounts    []SettingsMount

	CSRF string
}

// SettingsMount is one row in the "Mounted projects" table. Mirrors the
// mountRow struct in handlers_settings.go — duplicated locally so this
// package doesn't have to import internal/web.
type SettingsMount struct {
	Slug       string
	EmbedName  string
	EmbedModel string
	EmbedDim   int
}

// Settings renders the top-level /settings page: embedding defaults + provider
// transport in an editable form, read-only storage paths, and the
// per-project mount table with re-embed actions. 1:1 port of
// templates/pages/settings.tmpl — same copy, same class names, same form
// field names (so handleGlobalSettingsUpdate keeps parsing them unchanged).
templ Settings(p SettingsProps) {
	<section class="settings-page">
		<header class="page-header">
			<h1>Server settings</h1>
			<p class="subtitle">
				Defaults for <em>new</em> projects, plus shared transport bits like the Ollama URL.
				Existing projects pin their own embedder in <code>project.yaml</code> — flip those via per-project Settings.
			</p>
			<p class="muted">
				Edits write to <code>{ p.ConfigPath }</code> and preserve any comments in that file.
				Loaded from: <code>{ p.ConfigSource }</code>.
			</p>
		</header>
		if p.FormError != "" {
			<div class="form-error" role="alert"><strong>Error:</strong> { p.FormError }</div>
		}
		<form method="post" action="/settings" class="stack settings-form">
			<fieldset class="settings-section">
				<legend>Embedding defaults</legend>
				<p class="hint">Used when registering a new project. Existing mounts keep whatever they pinned in <code>project.yaml</code>.</p>
				<label for="embed_provider">Default embed provider</label>
				<select id="embed_provider" name="embed_provider">
					if p.EmbedProvider == "ollama" {
						<option value="ollama" selected>ollama</option>
					} else {
						<option value="ollama">ollama</option>
					}
					if p.EmbedProvider == "openai" {
						<option value="openai" selected>openai</option>
					} else {
						<option value="openai">openai</option>
					}
				</select>
				<label for="embed_model">Default embed model</label>
				<input type="text" id="embed_model" name="embed_model" value={ p.EmbedModel } placeholder="nomic-embed-text"/>
			</fieldset>
			<fieldset class="settings-section">
				<legend>Provider transport</legend>
				<p class="hint">Where this server reaches out to talk to its embedders.</p>
				<label for="ollama_url">Ollama URL</label>
				<input type="text" id="ollama_url" name="ollama_url" value={ p.OllamaURL } placeholder="http://localhost:11434"/>
				<label for="openai_api_key">
					OpenAI API key
					if p.KeyMasked {
						<span class="badge-inline">currently set — type to overwrite</span>
					}
				</label>
				if p.KeyMasked {
					<input type="password" id="openai_api_key" name="openai_api_key" placeholder="••••••••" autocomplete="off"/>
				} else {
					<input type="password" id="openai_api_key" name="openai_api_key" placeholder="sk-…" autocomplete="off"/>
				}
			</fieldset>
			<input type="hidden" name="_csrf" value={ p.CSRF }/>
			<div class="form-actions">
				<button type="submit">Save settings</button>
			</div>
		</form>
		<section class="settings-readonly" aria-label="Storage paths">
			<h2>Storage</h2>
			<p class="hint">Read-only — set via <code>config.yaml</code> or environment variables.</p>
			<dl class="kv-list">
				<dt>Per-repo data dir</dt>
				<dd>
					<code>{ p.DataDir }</code>
					<span class="kv-aside">project content checked into each repo</span>
				</dd>
				<dt>Shared data root</dt>
				<dd>
					<code>{ p.DataRoot }</code>
					<span class="kv-aside">cross-repo agent + mount cache</span>
				</dd>
			</dl>
		</section>
		<section class="settings-mounts">
			<h2>Mounted projects</h2>
			<p class="hint">Currently mounted projects with their per-project embedder. Re-embed rebuilds that project's index.</p>
			if len(p.Mounts) > 0 {
				<table class="data-table">
					<thead>
						<tr>
							<th>Project</th>
							<th>Embed provider</th>
							<th>Embed model</th>
							<th>Dim</th>
							<th class="ra">Actions</th>
						</tr>
					</thead>
					<tbody>
						for _, m := range p.Mounts {
							<tr>
								<td><a href={ templ.SafeURL("/p/" + m.Slug) }>{ m.Slug }</a></td>
								<td>{ m.EmbedName }</td>
								<td><code>{ m.EmbedModel }</code></td>
								<td>{ strconv.Itoa(m.EmbedDim) }</td>
								<td class="ra">
									<form method="post" action={ templ.SafeURL("/p/" + m.Slug + "/reembed") } class="inline-form">
										<input type="hidden" name="_csrf" value={ p.CSRF }/>
										<button type="submit" class="btn-link">Re-embed</button>
									</form>
								</td>
							</tr>
						}
					</tbody>
				</table>
				<form method="post" action="/settings/reembed-all" class="inline-form mounts-bulk">
					<input type="hidden" name="_csrf" value={ p.CSRF }/>
					<button type="submit" class="btn">Re-embed all projects</button>
					<span class="hint">Useful after switching the default embed model.</span>
				</form>
			} else {
				<p class="muted">No projects mounted yet.</p>
			}
		</section>
	</section>
}
